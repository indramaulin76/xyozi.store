# --------------------------------------------------------------------
# Production Environment Template
# Copy this file to `.env` on production server
# --------------------------------------------------------------------

# --------------------------------------------------------------------
# ENVIRONMENT
# --------------------------------------------------------------------
CI_ENVIRONMENT = production

# --------------------------------------------------------------------
# APP
# --------------------------------------------------------------------
app.baseURL = 'https://domainkamu.com/'
app.forceGlobalSecureRequests = true

# --------------------------------------------------------------------
# DATABASE
# --------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = topupgames_prod
database.default.username = topup_user
database.default.password = GANTI_PASSWORD_DB_KUAT
database.default.DBDriver = MySQLi
database.default.DBPrefix =

# --------------------------------------------------------------------
# INTERNAL ROUTE PROTECTION (for /sistem/*)
# --------------------------------------------------------------------
internal.systemKey = GANTI_DENGAN_RANDOM_SECRET_PANJANG

# --------------------------------------------------------------------
# COOKIE / SESSION SECURITY
# --------------------------------------------------------------------
cookie.prefix =
cookie.expires = 0
cookie.path = /
cookie.domain =
cookie.secure = true
cookie.httponly = true
cookie.samesite = 'Lax'
cookie.raw = false

app.sessionDriver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
app.sessionCookieName = 'ci_session'
app.sessionExpiration = 7200
app.sessionSavePath = 'ci_sessions'
app.sessionMatchIP = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false

# --------------------------------------------------------------------
# CSRF (enable when forms are fully aligned)
# --------------------------------------------------------------------
# security.csrfProtection = 'cookie'
# security.tokenName = 'csrf_token_name'
# security.headerName = 'X-CSRF-TOKEN'
# security.cookieName = 'csrf_cookie_name'
# security.expires = 7200
# security.regenerate = true
# security.redirect = true
# security.samesite = 'Lax'

# --------------------------------------------------------------------
# LOGGER
# --------------------------------------------------------------------
# logger.threshold = 4

# --------------------------------------------------------------------
# ENCRYPTION (optional but recommended if app uses encryption service)
# --------------------------------------------------------------------
# encryption.key = GANTI_KEY_RANDOM_PANJANG
# encryption.driver = OpenSSL
# encryption.blockSize = 16
# encryption.digest = SHA512
